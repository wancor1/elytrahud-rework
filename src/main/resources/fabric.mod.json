{
    "schemaVersion": 1,
    "id": "elytrahud",
    "version": "2.0.0",

    "name": "ElytraHud (MFS 2020)",
    "description": "Microsoft flight simulator HUD for Minecraft elytras",
    "authors": [
        "inorganic"
    ],
    "contact": {
        "homepage": "https://github.com/wancor1/elytrahud-rework",
        "issues": "https://github.com/wancor1/elytrahud-rework/issues"
    },

    "license": "MIT",
    "icon": "assets/elytrahud/icon.png",

    "environment": "client",
    "entrypoints": {
        "client": [
          {
            "adapter": "kotlin",
            "value": "inorganic.elytrahud.Common"
          }
        ],
        "modmenu": [
            "inorganic.elytrahud.ElytraHudModMenu"
        ]
    },
    "mixins": [
        "elytrahud.mixins.json"
    ],
    "depends": {
        "fabric-language-kotlin": ">=1.13.9",
        "fabricloader": ">=0.18.4",
        "fabric-api": "*",
        "minecraft": ">=26.1",
        "java": ">=25"
    },
    "suggests": {
		"modmenu": ">=8.0.0"
	},
    "custom": {
        "modmenu:api": "inorganic.elytrahud.ElytraHudModMenu",
        "modmenu": {
            "links": {
                "modmenu.modrinth": "https://modrinth.com/mod/elytra-hud-rework"
            }
        }
    }
}